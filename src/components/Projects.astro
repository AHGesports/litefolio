<script>
  // PERF FIX: Pause animate-ping when Synth section is not visible
  const synthSection = document.getElementById('synth-section');
  const pingDot = document.getElementById('dev-ping-dot');

  if (synthSection && pingDot) {
    const observer = new IntersectionObserver(
      (entries) => {
        pingDot.style.animationPlayState = entries[0].isIntersecting ? 'running' : 'paused';
      },
      { threshold: 0 }
    );
    observer.observe(synthSection);
  }
</script>
